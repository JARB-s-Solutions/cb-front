# Frontend Environment Variables
# Copy this file to .env and adjust values as needed

# Backend API URL (only used if backend is NOT on localhost:3000)
# Leave empty to use Vercel backend by default
VITE_API_PROXY=https://controlbarber-backend.vercel.app

# For local development pointing to local backend at http://localhost:3000
# Uncomment the line below:
# VITE_API_PROXY=http://localhost:3000

# Google OAuth (if needed)
VITE_GOOGLE_CLIENT_ID=your_google_client_id_here
